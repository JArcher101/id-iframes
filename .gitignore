# IDE and editor (local only — do not commit)
.vscode/
.idea/
.cursor/
*.code-workspace

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor swap files
*.swp
*.swo
*~

# Temporary / logs
*.tmp
*.temp
*.log

# Local assets and tools (not deployed)
fonts/
backend/
spreadsheet-merger.html
iframe-version-log-viewer.html
plan.md
sdlt-calculator.md

# AWS / infrastructure (sensitive)
aws-setup/
AWS-CLOUDFRONT-SIGNED-URLS-SUMMARY.md
AWS-SETUP-SUMMARY.md
CLOUDFRONT-DNS-TROUBLESHOOTING.md
error-pages/CLOUDFRONT-ERROR-PAGES-SETUP.md

